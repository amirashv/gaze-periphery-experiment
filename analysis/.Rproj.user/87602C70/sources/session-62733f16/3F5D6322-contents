# Setup

```{r}
library(tidyverse)

# ---- CHANGE THESE TWO LINES FOR EACH PARTICIPANT ----
TRIALS_FILE <- "trials_Pilot 2 copy.csv"                 # your trials CSV filename
PARTICIPANT_ID <- "pilot_2"   # participant label
```

# Data preparation

Reads the trials CSV, filters to valid trials only (fixation compliance and tracking quality), 
and converts variables to correct types.
```{r}
D_0 <- read_csv(TRIALS_FILE, show_col_types = FALSE)

D_1 <- D_0 |>
  filter(valid == 1) |>
  mutate(
    Part        = as.factor(PARTICIPANT_ID),
    condition   = as.factor(condition),
    eccentricity = as.numeric(eccentricity),
    magnitude   = as.numeric(magnitude),
    correct     = as.numeric(correct)
  ) |>
  group_by(condition) |>
  mutate(trial = row_number()) |>
  ungroup() |>
  select(Part, trial, condition, eccentricity, magnitude, correct,
         srt_ms, keyboard_rt_ms, pre_change_ms)

summary(D_1)
```

# Exploration

## Detection accuracy by eccentricity

Shows the sigmoid decrease in detection accuracy as eccentricity increases. 
Control and QuadBright conditions shown separately.
Dashed line = chance level (50%) for 2AFC task.

```{r}
#| fig-width: 8
#| fig-height: 5

T_1 <- D_1 |>
  summarize(
    p_correct = mean(correct),
    n_Obs     = n(),
    .by       = c(condition, eccentricity)
  )

T_1 |>
  ggplot(aes(x = eccentricity, 
             color = condition, 
             y = p_correct)) +
  geom_hline(yintercept = 0.5, linetype = "dashed", 
             color = "gray50") +
  geom_point(alpha = 0.6) +
  geom_smooth(se = FALSE, method = "loess", span = 0.8) +
  scale_y_continuous(limits = c(0.3, 1.05),
                     labels = scales::percent_format()) +
  scale_color_manual(values = c("control" = "#2196F3", 
                                "quadbright" = "#FF5722")) +
  labs(
    title    = paste("Proportion correct by eccentricity —", PARTICIPANT_ID),
    subtitle = "Dashed line = chance (50%)",
    x        = "Eccentricity (degrees from fixation)",
    y        = "Proportion correct",
    color    = "Condition",
  ) +
  theme_minimal(base_size = 13)
```

